@page
@model TicketSystem.Models.Ticket

<h2>Create New Ticket</h2>

<form asp-action="Create" method="post">
    <div class="form-group mb-2">
        <label asp-for="PassengerName"></label>
        <input asp-for="PassengerName" class="form-control" required />
    </div>
    
    <div class="form-group mb-3">
        <label asp-for="Destination"></label>
        <input asp-for="Destination" class="form-control" required />
    </div>
    
    <button type="submit" class="btn btn-success">Save Ticket</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
